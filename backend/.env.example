PORT=3000
NODE_ENV=development

# 数据在哪个库，由这一行决定。改库名 = 换了一套数据，不是「删数据」。
# 你原来的待办若在 sub_pm，请保持下面这一行（或复制到 .env）：
DATABASE_URL=postgresql://postgres:123456@localhost:5432/sub_pm

# 若希望与本机其它项目完全隔离，可新建库后改用例如：
# DATABASE_URL=postgresql://postgres:123456@localhost:5432/ai_project_pm

# 可选：连接串若包含以下任一字串则拒绝启动（防误连父项目主机名等）
# DATABASE_URL_BLOCKED_SUBSTRINGS=parent-prod.example.com

JWT_SECRET=pm-module-secret
ALLOW_DEV_AUTH_BYPASS=true

# 团队负载（/api/workload/team）：每人每周有效产能人时；月视图产能 = 该值 × WORKLOAD_MONTH_WEEKS
# WORKLOAD_CAPACITY_HOURS_PER_USER_WEEK=32
# WORKLOAD_DEFAULT_HOURS_PER_TASK=8
# WORKLOAD_MONTH_WEEKS=4
